# --- Required in production (Railway Variables) ---
SECRET_KEY=change-me-generate-with-django-get-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Domain (Railway custom domain) ---
CUSTOM_DOMAIN=daluailiraq.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://daluailiraq.com,https://www.daluailiraq.com

# --- Database ---
# Railway injects DATABASE_URL when PostgreSQL is attached
# ALLOW_SQLITE_FALLBACK=True  # emergency only

# --- Security (Railway handles SSL at proxy) ---
SECURE_SSL_REDIRECT=False

# --- Email Settings ---
DEFAULT_FROM_EMAIL=noreply@daluailiraq.com
SERVER_EMAIL=admin@daluailiraq.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- Optional ---
REDIS_URL=redis://localhost:6379/0
USE_WEBSOCKETS=False
SITE_NAME=دلال

# --- Performance ---
CACHE_TIMEOUT=300

# --- Social Authentication ---
# Google OAuth 2.0
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your-google-client-id
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your-google-client-secret

# Facebook OAuth 2.0
SOCIAL_AUTH_FACEBOOK_OAUTH2_KEY=your-facebook-app-id
SOCIAL_AUTH_FACEBOOK_OAUTH2_SECRET=your-facebook-app-secret
